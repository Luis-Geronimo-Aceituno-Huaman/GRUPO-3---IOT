# .env.example — plantilla de credenciales y parametros del sistema.
# Copiala a .env y completa los valores reales:
#     cp .env.example .env
#
# La leen capa3/config.py (gateway, camara) y capa3/monitor/config.py (dashboard).
# El broker exige usuario/contrasena (capa2-red: allow_anonymous false), por lo que
# MQTT_USER/MQTT_PASS deben coincidir con capa2-red/passwd y con el config.h del ESP32.

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=esp32
MQTT_PASS=cambia-esta-clave

# --- PostgreSQL (docker-compose.yml de la raiz) ---
# PG_PORT 5433 en la laptop de desarrollo (el 5432 lo ocupa otro proyecto);
# en una VM limpia puede ser 5432 (cambiar tambien el mapeo del compose).
PG_HOST=localhost
PG_PORT=5433
PG_USER=iot
PG_PASS=cambia-esta-clave
PG_DB=iot_mosquito

# --- Auth del dashboard (capa 4) ---
SESSION_SECRET=un-secreto-largo-y-aleatorio
ADMIN_INIT_PASS=clave-inicial-del-admin   # la usa el migrador al crear el usuario 'admin'
